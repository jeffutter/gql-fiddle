{
  "name": "gql-fiddle-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/gql-core --target web --out-dir ../../web/src/wasm",
    "dev": "pnpm build:wasm && concurrently --kill-others-on-fail \"cargo watch --watch $(pwd)/../crates/gql-core/src -s 'pnpm --dir $(pwd) build:wasm'\" \"vite\"",
    "dev:full": "pnpm build:wasm && concurrently --kill-others-on-fail --names wasm,vite,wrangler \"cargo watch --watch $(pwd)/../crates/gql-core/src -s 'pnpm --dir $(pwd) build:wasm'\" \"vite\" \"cd $(pwd)/.. && wrangler pages dev web/dist\"",
    "dev:no-wasm": "vite",
    "pages:dev": "cd .. && wrangler pages dev web/dist",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "e2e": "playwright test",
    "test:functions": "vitest run --config vitest.functions.config.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.11.1",
    "elkjs": "^0.11.1",
    "graphql": "^17.0.1",
    "js-yaml": "^5.1.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "monaco-graphql": "^1.8.0",
    "monaco-vim": "^0.4.4",
    "pako": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "better-sqlite3": "^11.10.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.0.0"
  }
}
